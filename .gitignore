# Python / Flask / Pygame / SQLite .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Often people dot tend to upload files generated by PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.status
.jscsrc
.jshintrc
.eslintignore
.eslintrc
.stylelintrc

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# SQLite databases (Persistent data should not be in git)
*.db
*.sqlite3

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Project specific
static/favicon.png
static/og-image.png
# (Actually we WANT these in git for the landing page, but maybe not the raw generated one from brain dir)
